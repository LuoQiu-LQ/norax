---
import Layout from '../layouts/Layout.astro'
import { getCollection } from 'astro:content'

const posts = await getCollection('posts')

// 收集所有标签并统计
const tagCount = posts.reduce((acc, post) => {
  if (post.data.tags) {
    post.data.tags.forEach(tag => {
      acc[tag] = (acc[tag] || 0) + 1
    })
  }
  return acc
}, {} as Record<string, number>)

const tags = Object.entries(tagCount).sort((a, b) => b[1] - a[1])
---

<Layout title="标签 - 墨白" description="按标签浏览文章">
  <section class="max-w-4xl mx-auto px-6 py-12">
    <header class="mb-12 text-center">
      <h1 class="text-3xl font-serif font-semibold text-ink mb-4">标签</h1>
      <p class="text-ink-light">共 {tags.length} 个标签</p>
    </header>
    
    <div class="flex flex-wrap gap-3 justify-center">
      {tags.map(([tag, count]) => (
        <a
          href={`/tags/${tag}`}
          class="inline-flex items-center gap-2 px-4 py-2 bg-cream-dark rounded-lg hover:bg-accent/20 hover:text-accent transition-colors"
        >
          <span>{tag}</span>
          <span class="text-xs text-ink-light">({count})</span>
        </a>
      ))}
    </div>
  </section>
</Layout>

<style is:global>
  .dark h1 {
    @apply text-[#e8e8e8];
  }
</style>
