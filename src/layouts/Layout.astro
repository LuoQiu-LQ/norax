---
import '../styles/global.css'
import { getCollection } from 'astro:content'

interface Props {
  title: string
  description?: string
}

const { title, description = '一个极简文艺的个人博客' } = Astro.props
const posts = await getCollection('posts')
const searchData = posts.map(post => ({
  id: post.id,
  title: post.data.title,
  description: post.data.description,
  tags: post.data.tags || []
}))
---

<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Source+Sans+3:wght@400;500;600&family=Source+Serif+4:ital,wght@0,400;0,600;1,400&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    
    <script is:inline>
      (function() {
        const savedTheme = localStorage.getItem('theme');
        if (savedTheme === 'dark') {
          document.documentElement.classList.add('dark');
        } else if (savedTheme === 'light') {
          document.documentElement.classList.remove('dark');
        } else if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>
    
    <script define:vars={{ searchData }}>
      window.searchData = searchData
    </script>
  </head>
  <body class="min-h-screen flex flex-col page-transition">
    <div id="theme-flash" class="fixed inset-0 pointer-events-none z-[100] opacity-0 transition-opacity duration-300" style="background-color: inherit;"></div>
    
    <div id="reading-progress" style="width: 0%"></div>
    
    <header class="sticky top-0 z-40 bg-cream/90 backdrop-blur-md border-b border-cream-dark">
      <nav class="max-w-5xl mx-auto px-6 lg:px-8 py-5 flex items-center justify-between">
        <a href="/" class="group flex items-center gap-3">
          <div class="w-10 h-10 rounded-full bg-gradient-to-br from-accent to-accent-light flex items-center justify-center text-white shadow-md group-hover:shadow-lg transition-shadow" style="font-family: 'Source Serif 4', serif; font-size: 1.5rem; line-height: 1;">
            落
          </div>
          <span class="text-xl font-serif font-semibold text-ink group-hover:text-accent transition-colors">
            落秋笔记
          </span>
        </a>
        
        <div class="hidden md:flex items-center gap-10">
          <a href="/" class="text-base font-medium text-ink-light hover:text-accent transition-colors relative group">
            <span>首页</span>
            <span class="absolute -bottom-1 left-0 w-0 h-0.5 bg-accent transition-all duration-300 group-hover:w-full"></span>
          </a>
          <a href="/archives" class="text-base font-medium text-ink-light hover:text-accent transition-colors relative group">
            <span>归档</span>
            <span class="absolute -bottom-1 left-0 w-0 h-0.5 bg-accent transition-all duration-300 group-hover:w-full"></span>
          </a>
          <a href="/tags" class="text-base font-medium text-ink-light hover:text-accent transition-colors relative group">
            <span>标签</span>
            <span class="absolute -bottom-1 left-0 w-0 h-0.5 bg-accent transition-all duration-300 group-hover:w-full"></span>
          </a>
          <a href="/about" class="text-base font-medium text-ink-light hover:text-accent transition-colors relative group">
            <span>关于</span>
            <span class="absolute -bottom-1 left-0 w-0 h-0.5 bg-accent transition-all duration-300 group-hover:w-full"></span>
          </a>
        </div>
        
        <div class="flex items-center gap-4">
          <button id="search-btn" class="p-2.5 text-ink-light hover:text-accent hover:bg-cream-dark rounded-lg transition-all" aria-label="搜索">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
          </button>
          
          <button id="theme-toggle" class="theme-toggle p-2 text-ink-light hover:text-accent hover:bg-cream-dark rounded-lg transition-all" aria-label="切换主题">
            <svg id="sun-icon" class="w-5 h-5 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
            </svg>
            <svg id="moon-icon" class="w-5 h-5 hidden transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
            </svg>
          </button>
          
          <button id="mobile-menu-btn" class="md:hidden p-2.5 text-ink-light hover:bg-cream-dark rounded-lg transition-all">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
          </button>
        </div>
      </nav>
    </header>
    
    <div id="mobile-menu" class="md:hidden fixed inset-0 bg-cream/98 backdrop-blur-md z-40 flex flex-col items-center justify-center gap-8 opacity-0 pointer-events-none transition-opacity duration-300">
      <a href="/" class="text-2xl font-serif text-ink hover:text-accent">首页</a>
      <a href="/archives" class="text-2xl font-serif text-ink hover:text-accent">归档</a>
      <a href="/tags" class="text-2xl font-serif text-ink hover:text-accent">标签</a>
      <a href="/about" class="text-2xl font-serif text-ink hover:text-accent">关于</a>
      <button id="close-menu" class="absolute top-6 right-6 text-3xl text-ink-light w-12 h-12 flex items-center justify-center hover:bg-cream-dark rounded-lg transition-all">&times;</button>
    </div>
    
    <main class="flex-1">
      <slot />
    </main>
    
    <footer class="mt-20 py-8 text-center border-t border-cream-dark">
      <div class="text-ink-light text-sm mb-2">
        &copy; {new Date().getFullYear()} 落秋笔记. All rights reserved.
      </div>
      <div id="global-stats" class="text-xs text-ink-light/60 flex items-center justify-center gap-4 opacity-0 transition-opacity duration-500 mt-2">
      </div>
    </footer>

    <button id="back-to-top" class="back-to-top" aria-label="返回顶部">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 10l7-7m0 0l7 7m-7-7v18" />
      </svg>
    </button>
    
    <div id="search-modal" class="search-modal">
      <div class="search-input-container w-full max-w-2xl mx-4">
        <div class="relative">
          <input type="text" id="modal-search-input" class="w-full bg-white dark:bg-[#1a1a1a] rounded-2xl shadow-2xl p-5 text-lg border border-cream-dark focus:border-accent outline-none transition-colors" placeholder="搜索文章... (按 ESC 关闭)" autocomplete="off" />
          <kbd class="absolute right-5 top-1/2 -translate-y-1/2 px-3 py-1.5 text-sm bg-cream-dark rounded-lg text-ink-light">ESC</kbd>
        </div>
        <div id="modal-search-results" class="mt-4 bg-white dark:bg-[#1a1a1a] rounded-2xl shadow-2xl max-h-96 overflow-y-auto"></div>
      </div>
    </div>
    
    <script is:inline>
      // 1. 获取全站动态统计数据
      document.addEventListener('DOMContentLoaded', () => {
        fetch('/api/stats')
          .then(r => r.json())
          .then(data => {
            const statsEl = document.getElementById('global-stats');
            if(statsEl && data.stats) {
              statsEl.innerHTML = `
                <span>共 ${data.stats.total_articles} 篇文章</span>
                <span>${data.stats.total_views} 次阅读</span>
                <span>${data.stats.total_comments} 条评论</span>
              `;
              statsEl.classList.remove('opacity-0');
            }
          })
          .catch(err => console.error('获取统计失败', err));
      });

      // 2. 主题切换
      function initThemeToggle() {
        const toggle = document.getElementById('theme-toggle')
        if (!toggle) return
        const newToggle = toggle.cloneNode(true)
        toggle.parentNode?.replaceChild(newToggle, toggle)
        newToggle.addEventListener('click', () => {
          const isDark = document.documentElement.classList.toggle('dark')
          localStorage.setItem('theme', isDark ? 'dark' : 'light')
          const sun = document.getElementById('sun-icon')
          const moon = document.getElementById('moon-icon')
          if (sun && moon) {
            if (isDark) { sun.classList.add('hidden'); moon.classList.remove('hidden'); }
            else { sun.classList.remove('hidden'); moon.classList.add('hidden'); }
          }
        })
      }
      
      // 3. 滚动与返回顶部
      function initScrollHandlers() {
        const progressBar = document.getElementById('reading-progress')
        const backToTop = document.getElementById('back-to-top')
        window.addEventListener('scroll', () => {
          const scrollTop = document.documentElement.scrollTop
          const scrollHeight = document.documentElement.scrollHeight - document.documentElement.clientHeight
          if (progressBar) progressBar.style.width = `${(scrollTop / scrollHeight) * 100}%`
          if (backToTop) {
            if (scrollTop > 300) backToTop.classList.add('visible')
            else backToTop.classList.remove('visible')
          }
        })
        if (backToTop) backToTop.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }))
      }

      // 4. 全局弹窗搜索 (基于预生成的静态数据)
      function initSearch() {
        const btn = document.getElementById('search-btn')
        const modal = document.getElementById('search-modal')
        const input = document.getElementById('modal-search-input')
        const results = document.getElementById('modal-search-results')
        const closeSearch = () => { modal?.classList.remove('active'); if(input) input.value=''; if(results) results.innerHTML=''; }
        btn?.addEventListener('click', () => { modal?.classList.add('active'); input?.focus(); })
        document.addEventListener('keydown', (e) => { if(e.key === 'Escape') closeSearch() })
        modal?.addEventListener('click', (e) => { if (e.target === modal) closeSearch() })
        input?.addEventListener('input', (e) => {
          const q = e.target.value.toLowerCase().trim()
          if (!q) { if(results) results.innerHTML = ''; return; }
          const match = window.searchData.filter(p => p.title.toLowerCase().includes(q) || p.description.toLowerCase().includes(q) || p.tags.some(t => t.toLowerCase().includes(q)))
          if (results) {
            results.innerHTML = match.length === 0 
              ? '<div class="p-6 text-center text-ink-light">没有找到相关文章</div>' 
              : match.map(p => `<a href="/posts/${p.id}" class="block p-5 hover:bg-cream-dark transition-colors border-b border-cream-dark last:border-b-0"><div class="font-medium text-ink text-lg">${p.title}</div><div class="text-sm text-ink-light mt-1">${p.description}</div></a>`).join('')
          }
        })
      }

      // 5. 移动端菜单
      function initMobileMenu() {
        const btn = document.getElementById('mobile-menu-btn')
        const menu = document.getElementById('mobile-menu')
        const close = document.getElementById('close-menu')
        btn?.addEventListener('click', () => { menu?.classList.remove('opacity-0', 'pointer-events-none'); menu?.classList.add('opacity-100'); })
        close?.addEventListener('click', () => { menu?.classList.add('opacity-0', 'pointer-events-none'); menu?.classList.remove('opacity-100'); })
      }

      // 初始化所有脚本
      initThemeToggle(); initScrollHandlers(); initSearch(); initMobileMenu();
      document.addEventListener('astro:page-load', () => { initThemeToggle(); initScrollHandlers(); initSearch(); initMobileMenu(); });
    </script>
  </body>
</html>