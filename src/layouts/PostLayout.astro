---
import Layout from './Layout.astro'

interface Props {
  title: string
  postId: string
  date: string
  tags?: string[]
  description?: string
}

const { title, postId, date, tags = [], description } = Astro.props

const formatDate = (dateStr: string) => {
  return new Date(dateStr).toLocaleDateString('zh-CN', {
    year: 'numeric',
    month: 'long',
    day: 'numeric'
  })
}

// 计算阅读时间
const getReadingTime = (content: string) => {
  const minutes = Math.ceil(content.length / 400)
  return minutes
}
---

<Layout title={`${title} - 墨白`} description={description}>
  <article class="max-w-3xl mx-auto px-6 py-12 md:py-16">
    <!-- 返回链接 -->
    <nav class="mb-12 opacity-0 animate-fade-in">
      <a 
        href="/"
        class="inline-flex items-center gap-2 text-sm text-ink-light hover:text-accent transition-colors group"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 transform group-hover:-translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
        <span>返回首页</span>
      </a>
    </nav>
    
    <!-- 文章头部 -->
    <header class="mb-12 text-center">
      {tags.length > 0 && (
        <div class="flex justify-center gap-2 mb-6 opacity-0 animate-fade-in" style="animation-delay: 0.1s; animation-fill-mode: forwards;">
          {tags.map(tag => (
            <a 
              href={`/tags/${tag}`}
              class="text-xs font-medium text-accent bg-accent/10 px-3 py-1 rounded-full hover:bg-accent hover:text-white transition-colors"
            >
              {tag}
            </a>
          ))}
        </div>
      )}
      
      <h1 transition:name={`title-${postId}`} class="text-3xl md:text-4xl lg:text-5xl font-serif font-bold text-ink mb-6 leading-tight opacity-0 animate-fade-in" style="animation-delay: 0.2s; animation-fill-mode: forwards;">
        {title}
      </h1>
      
      <div class="flex items-center justify-center gap-6 text-sm text-ink-light opacity-0 animate-fade-in" style="animation-delay: 0.3s; animation-fill-mode: forwards;">
        <time datetime={date}>{formatDate(date)}</time>
        <span class="w-1 h-1 rounded-full bg-ink-light/50"></span>
        <span>约 {getReadingTime(description || '')} 分钟阅读</span>
      </div>
      
      <div class="w-16 h-0.5 bg-accent mx-auto mt-8 opacity-0 animate-fade-in" style="animation-delay: 0.4s; animation-fill-mode: forwards;"></div>
    </header>
    
    <!-- 文章内容 -->
    <div class="prose prose-lg mx-auto opacity-0 animate-fade-in" style="animation-delay: 0.5s; animation-fill-mode: forwards;">
      <slot />
    </div>
    
    <!-- 文章底部 -->
    <footer class="mt-16 pt-8 border-t border-cream-dark">
      <!-- 标签 -->
      {tags.length > 0 && (
        <div class="mb-8">
          <div class="text-sm text-ink-light mb-3">标签</div>
          <div class="flex flex-wrap gap-2">
            {tags.map(tag => (
              <a 
                href={`/tags/${tag}`}
                class="text-sm text-ink-light bg-cream-dark px-3 py-1 rounded hover:bg-accent/20 hover:text-accent transition-colors"
              >
                #{tag}
              </a>
            ))}
          </div>
        </div>
      )}
      
      <!-- 分享 -->
      <div class="mb-8">
        <div class="text-sm text-ink-light mb-3">分享</div>
        <div class="flex gap-4">
          <button 
            onclick={`navigator.clipboard.writeText(window.location.href)`}
            class="flex items-center gap-2 text-sm text-ink-light bg-cream-dark px-4 py-2 rounded hover:bg-accent/20 hover:text-accent transition-colors"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3" />
            </svg>
            <span>复制链接</span>
          </button>
        </div>
      </div>
      
      <!-- 返回 -->
      <a 
        href="/"
        class="inline-flex items-center gap-2 text-sm text-ink-light hover:text-accent transition-colors group"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 transform group-hover:-translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
        <span>返回首页</span>
      </a>
    </footer>

    <!-- 浏览量统计 -->
    <div class="mt-8 flex items-center gap-2 text-sm text-ink-light">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
      </svg>
      <span id="view-count">-- 次阅读</span>
    </div>

    <!-- 评论区 -->
    <div class="mt-16 pt-8 border-t border-cream-dark">
      <h3 class="text-lg font-serif font-semibold text-ink mb-8">评论</h3>

      <!-- 评论列表 -->
      <div id="comments-list" class="space-y-6 mb-10">
        <p class="text-sm text-ink-light">加载评论中...</p>
      </div>

      <!-- 发表评论表单 -->
      <div class="bg-cream rounded-xl p-6 border border-cream-dark">
        <h4 class="text-sm font-medium text-ink mb-4">发表评论</h4>
        <div class="space-y-4">
          <input
            id="comment-author"
            type="text"
            placeholder="你的昵称"
            maxlength="50"
            class="w-full px-4 py-2 rounded-lg border border-cream-dark bg-white text-ink text-sm focus:outline-none focus:border-accent transition-colors"
          />
          <textarea
            id="comment-content"
            placeholder="写下你的想法... (最多500字)"
            maxlength="500"
            rows="4"
            class="w-full px-4 py-2 rounded-lg border border-cream-dark bg-white text-ink text-sm focus:outline-none focus:border-accent transition-colors resize-none"
          ></textarea>
          <div class="flex items-center justify-between">
            <span id="comment-msg" class="text-xs text-ink-light"></span>
            <button
              id="comment-submit"
              class="px-6 py-2 bg-accent text-white text-sm rounded-lg hover:bg-accent/80 transition-colors"
            >
              发表评论
            </button>
          </div>
        </div>
      </div>
    </div>
  </article>
</Layout>

<script define:vars={{ postId }}>
  const API = 'http://luoqiu.xyz/api';

  // ── 浏览量 ──
  fetch(`${API}/views/${postId}`, { method: 'POST' })
    .then(r => r.json())
    .then(d => {
      document.getElementById('view-count').textContent = `${d.views} 次阅读`;
    });

  // ── 加载评论 ──
  const loadComments = () => {
    fetch(`${API}/comments/${postId}`)
      .then(r => r.json())
      .then(d => {
        const list = document.getElementById('comments-list');
        if (!d.comments || d.comments.length === 0) {
          list.innerHTML = '<p class="text-sm text-ink-light">还没有评论，来第一个吧！</p>';
          return;
        }
        list.innerHTML = d.comments.map(c => `
          <div class="flex gap-4 group" id="comment-${c.id}">
            <div class="w-8 h-8 rounded-full bg-accent/20 flex items-center justify-center text-accent text-sm font-medium flex-shrink-0">
              ${c.author.charAt(0).toUpperCase()}
            </div>
            <div class="flex-1">
              <div class="flex items-center gap-3 mb-1">
                <span class="text-sm font-medium text-ink">${c.author}</span>
                <span class="text-xs text-ink-light">${new Date(c.created_at).toLocaleString('zh-CN')}</span>
                <button 
                  onclick="deleteComment(${c.id})"
                  class="text-xs text-red-400 hover:text-red-600 ml-auto opacity-0 group-hover:opacity-100 transition-opacity"
                  title="删除评论"
                >
                  删除
                </button>
              </div>
              <p class="text-sm text-ink-light leading-relaxed">${c.content}</p>
            </div>
          </div>
        `).join('');
      });
  };
  loadComments();

  // ── 删除评论 ──
  window.deleteComment = (commentId) => {
    if (!confirm('确定要删除这条评论吗？')) return;
    
    fetch(`${API}/comments/${commentId}`, { method: 'DELETE' })
      .then(r => r.json())
      .then(d => {
        if (d.success) {
          const el = document.getElementById(`comment-${commentId}`);
          if (el) el.remove();
        } else {
          alert(d.error || '删除失败');
        }
      });
  };

  // ── 发表评论 ──
  document.getElementById('comment-submit').addEventListener('click', () => {
    const author = document.getElementById('comment-author').value.trim();
    const content = document.getElementById('comment-content').value.trim();
    const msg = document.getElementById('comment-msg');

    if (!author) { msg.textContent = '请填写昵称'; return; }
    if (!content) { msg.textContent = '请填写评论内容'; return; }

    document.getElementById('comment-submit').disabled = true;
    msg.textContent = '提交中...';

    fetch(`${API}/comments/${postId}`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ author, content })
    })
      .then(r => r.json())
      .then(d => {
        if (d.success) {
          document.getElementById('comment-author').value = '';
          document.getElementById('comment-content').value = '';
          msg.textContent = '评论发表成功！';
          loadComments();
        } else {
          msg.textContent = d.error || '发表失败，请重试';
        }
      })
      .finally(() => {
        document.getElementById('comment-submit').disabled = false;
      });
  });
</script>

<style is:global>
  .dark h1 {
    color: #e8e8e8;
  }
  .dark header h1 {
    color: #e8e8e8;
  }
  
  @keyframes fade-in {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  
  .animate-fade-in {
    animation: fade-in 0.6s cubic-bezier(0.4, 0, 0.2, 1) forwards;
  }
</style>
